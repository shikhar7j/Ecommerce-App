# ==========================================
# Dependencies (Using **/ to match subfolders)
# ==========================================
**/node_modules/
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# ==========================================
# Environment & Secrets (Crucial for subfolders)
# ==========================================
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.env
server/.env

# ==========================================
# Build & Output Directories
# ==========================================
**/dist/
**/dist-ssr/
**/build/
**/.next/
**/.out/
**/coverage/

# ==========================================
# Logs
# ==========================================
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# ==========================================
# Editor directories and files
# ==========================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
**/_DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?